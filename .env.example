# Langfuse credentials - get these from https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Optional: self-hosted Langfuse URL (defaults to cloud.langfuse.com)
# LANGFUSE_BASE_URL=https://your-langfuse-instance.com

# ── Integration tests (Docker) ──────────────────────────
# Set these to run tests against the local Docker Langfuse stack.
# Start the stack first: docker compose -f docker-compose.test.yml up --wait
# LANGFUSE_INTEGRATION_TEST=true
# LANGFUSE_BASE_URL=http://localhost:3033
# LANGFUSE_SECRET_KEY=sk-lf-test
# LANGFUSE_PUBLIC_KEY=pk-lf-test
